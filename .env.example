# API
PORT=8787
HOST=0.0.0.0
DATA_DIR=.data
WEB_ORIGIN=http://localhost:5173

# LLM provider
# OpenAI-compatible Chat Completions endpoint. No mock fallback is used by the app runtime.
LLM_PROVIDER=openai-compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini

# Persistent store
# SQLite is the only persistent Store.
# Relative DATA_DIR values are resolved from the repository root.
# All Session/State/Memory/Artifact/Knowledge/EventTrace data is saved under DATA_DIR/writing-assistant.sqlite.

# Workflow execution is handled by pi-agent inside the API process.
# There is no workflow queue or worker toggle in the current runtime.

# Real RAG over HTTP
# local: built-in demo knowledge store.
# http: POST to generic /search-style RAG service.
# tonglingyu: POST to tonglingyu-knownledge retriever /retrieve.
RAG_PROVIDER=local
RAG_BASE_URL=http://localhost:9000
RAG_API_KEY=
RAG_SEARCH_PATH=/search
RAG_REFS_PATH=/refs
RAG_TIMEOUT_MS=10000

# Web
VITE_API_BASE=http://localhost:8787
