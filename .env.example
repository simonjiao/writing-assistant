# API
PORT=8787
HOST=0.0.0.0
DATA_DIR=.data
WEB_ORIGIN=http://localhost:5173

# LLM provider
# mock keeps the app fully runnable without a model key.
# openai-compatible supports OpenAI-compatible Chat Completions endpoints.
LLM_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini

# Persistent store
# SQLite is the only persistent Store.
# Relative DATA_DIR values are resolved from the repository root.
# All Session/State/Memory/Artifact/Knowledge/EventTrace data is saved under DATA_DIR/writing-assistant.sqlite.

# Workflow execution
# inline: API request runs workflow immediately.
# async: API request enqueues workflow run and workers process it.
WORKFLOW_EXECUTION_MODE=async
ENABLE_WORKERS=true
RUNNER_CONCURRENCY=2

# Queue driver for async mode
# local: in-process queue, no extra service.
# redis: Redis-backed queue, supports multiple API/worker processes.
WORKFLOW_QUEUE_DRIVER=local
REDIS_URL=redis://localhost:6379

# Real RAG over HTTP
# local: built-in demo knowledge store.
# http: POST to generic /search-style RAG service.
# tonglingyu: POST to tonglingyu-knownledge retriever /retrieve.
RAG_PROVIDER=local
RAG_BASE_URL=http://localhost:9000
RAG_API_KEY=
RAG_SEARCH_PATH=/search
RAG_REFS_PATH=/refs
RAG_TIMEOUT_MS=10000

# Web
VITE_API_BASE=http://localhost:8787
