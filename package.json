{
  "name": "writing-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Workflow-driven writing assistant with TypeScript, Fastify, React, pi-agent workflows, externalized state/memory/artifacts.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:node": "node scripts/check-node-version.cjs",
    "preinstall": "node scripts/check-node-version.cjs",
    "prebuild": "node scripts/check-node-version.cjs",
    "build": "npm run build --workspace @wa/core && npm run build --workspace @wa/runtime && npm run build --workspace @wa/writing-assistant && npm run build --workspace @wa/api && npm run build --workspace @wa/web",
    "predev": "node scripts/check-node-version.cjs",
    "dev": "npm run build --workspace @wa/core && npm run build --workspace @wa/runtime && npm run build --workspace @wa/writing-assistant && npm run dev --workspace @wa/api",
    "predev:web": "node scripts/check-node-version.cjs",
    "dev:web": "npm run dev --workspace @wa/web",
    "local:start": "node scripts/local-runtime.mjs start",
    "local:status": "node scripts/local-runtime.mjs status",
    "local:stop": "node scripts/local-runtime.mjs stop",
    "local:restart": "node scripts/local-runtime.mjs restart",
    "workflow:reset-pi": "node scripts/reset-pi-workflow-state.cjs --apply",
    "workflow:reset-pi:dry-run": "node scripts/reset-pi-workflow-state.cjs",
    "pretest": "node scripts/check-node-version.cjs && npm run build --workspace @wa/core && npm run build --workspace @wa/runtime && npm run build --workspace @wa/writing-assistant",
    "test": "vitest run packages/core/src/context.test.ts packages/core/src/llm.test.ts packages/runtime/src/product-skill.test.ts packages/runtime/src/pi-workflow-runner.test.ts packages/runtime/src/prompt-template.test.ts packages/writing-assistant/src/product.test.ts packages/writing-assistant/src/workflows/writing-autopilot/allowed-actions.test.ts packages/writing-assistant/src/skills/create-task-card/programs/task-card-builder.test.ts packages/writing-assistant/src/skills/revise-task-card/programs/task-card-reviser.test.ts packages/writing-assistant/src/skills/create-revision-proposal/programs/dialogue-coordinator.test.ts packages/writing-assistant/src/skills/plan-outline/programs/outline-item-reviser.test.ts packages/writing-assistant/src/skills/plan-outline/programs/outline-reviser.test.ts packages/writing-assistant/src/skills/plan-outline/programs/outline-planner.test.ts packages/writing-assistant/src/skills/write-section/programs/section-writer.test.ts packages/writing-assistant/src/skills/resolve-article-comment/programs/article-comment-resolver.test.ts apps/api/src/app.test.ts apps/api/src/writing-autopilot.acceptance.test.ts apps/web/src/workflowDialogueState.test.ts",
    "pretest:browser": "node scripts/check-node-version.cjs",
    "test:browser": "playwright test",
    "test:browser:local": "RAG_PROVIDER=local RAG_BASE_URL= npm run local:restart && npm run test:browser",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "clean": "rimraf apps/*/dist apps/*/dist-ts packages/*/dist .data apps/*/.data"
  },
  "engines": {
    "node": ">=22.19.0 <23"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
